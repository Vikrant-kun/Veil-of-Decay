      m_Calls: []
  m_text: 'The Veil breached his sanctuary. He watched, helpless, as the curse seized
    his family: smiles turned to screams, laughter to cries, life to chilling stillness.
    Their forms dissolved into dust. A wound tore his soul. Then, the foul essence
    consumed him, flesh twisting, being warped, dragged into the same torment.'
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: d76c4b9df01da4ed287ac895aaeaaf01, type: 2}
