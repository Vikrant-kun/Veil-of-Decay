  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Even the divine fell. Serphina, Azure, Aurelia \u2013 Aerthos's sacred
    guardians, their boundless light once shielding the realm. But the Abyssal Lord's
    curse defiled the heavens. Their radiant forms now flicker, powers dwindled to
    embers. Trapped, corrupted by the relentless Veil, they watch their world crumble,
    hope replaced by despair."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: d76c4b9df01da4ed287ac895aaeaaf01, type: 2}
  m_sharedMaterial: {fileID: 6587870914143440735, guid: d76c4b9df01da4ed287ac895aaeaaf01, type: 2}
