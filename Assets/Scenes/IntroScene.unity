  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "The joy of Aerthos splintered. From abyssal chasms, the Abyssal Lord rose\u2014a
    titan of shadow and void. Its burning eyes unleashed a grotesque curse, a blight
    seeping into the world's very soul. Lands withered, life choked to silence. Aerthos
    wept, draped in the suffocating Veil of Decay. Desolation claimed all."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: d76c4b9df01da4ed287ac895aaeaaf01, type: 2}
  m_sharedMaterial: {fileID: 6587870914143440735, guid: d76c4b9df01da4ed287ac895aaeaaf01, type: 2}
