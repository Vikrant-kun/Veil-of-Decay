MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 378027079}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 8ba93c78a1907496c947f68ff563cd8f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  loreCanvasGroup: {fileID: 1236521027}
  loreText: {fileID: 310750632}
  abilityUnlockedImage: {fileID: 249502933}
  abilityDescriptionText: {fileID: 237798192}
  additionalImage1: {fileID: 2028868905}
  additionalImage2: {fileID: 1998323813}
  hpIncreaseImage: {fileID: 581463727}
  hpIncreaseText: {fileID: 226195703}
  locationNameCanvasGroup: {fileID: 430410850}
  locationNameText: {fileID: 113881808}
  locationNameDisplayTime: 2
  fadeDuration: 2
  nextSceneName: Level2
  loreContent: "As the Firstborn fell, the void itself trembled. From his shadowed
    throne, the Abyssal Lord unleashed the Great Corruption, a tendril of ancient
    malice spreading across the lands.\n\nEven as Demon Wood found respite, a chilling
    power stirred. The Secondborn, the Lich Lord of the Whispering Woods, twisted
    the encroaching darkness to a new, necromantic will, binding the very essence
    of the Dark Forest.\n\nBut from the sacred glades, the radiant Guardian, Seraphina,
    emerged. Sensing your triumph, and the looming shadow, she bestowed upon you
    a fragment of her divine power \u2013 a piercing grace forged in defiance."
  abilityDescriptionContent: 'New Ability Unlocked!

    Crimson Aegis Strike


    Effect
    on enemies: Spirit Burn


    What it does: Each of your basic attacks now deals
    a small amount of bonus holy/spirit damage in addition to your normal physical
    damage. This bonus damage is particularly potent against corrupted foes.'
  oldMaxHP: 500
  newMaxHP: 700
  healFlaskIncreaseImage: {fileID: 1463673869}
  healFlaskIncreaseText: {fileID: 2145535185}
  pressAnyKeyPromptText: {fileID: 195582616}
